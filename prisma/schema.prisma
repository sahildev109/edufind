generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id              String            @id @default(cuid())
  slug            String            @unique
  name            String
  shortName       String?
  state           String
  city            String
  type            CollegeType
  category        String
  naacGrade       String?
  nirfRank        Int?
  establishedYear Int?
  description     String?
  imageUrl        String?
  websiteUrl      String?
  feesMin         Int
  feesMax         Int
  avgPackageLpa   Float?
  maxPackageLpa   Float?
  placementRate   Float?
  overallRating   Float             @default(0)
  reviewCount     Int               @default(0)
  facilities      CollegeFacility[]
  courses         Course[]
  placements      PlacementStat[]
  reviews         Review[]
  savedBy         SavedItem[]

  @@index([state, city])
  @@index([type])
  @@index([nirfRank])
  @@index([feesMin, feesMax])
  @@index([overallRating])
  @@index([name, city, state])
}

model Course {
  id            String  @id @default(cuid())
  collegeId     String
  name          String
  degree        String
  branch        String
  durationYrs   Int
  feesPerYear   Int
  seats         Int?
  cutoffJeeMain Int?
  cutoffJeeAdv  Int?
  college       College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
  @@index([branch])
}

model PlacementStat {
  id               String   @id @default(cuid())
  collegeId        String
  year             Int
  avgPackageLpa    Float
  maxPackageLpa    Float
  medianPackageLpa Float?
  placedStudents   Int
  totalStudents    Int
  topRecruiters    String[]
  college          College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId, year])
}

model CollegeFacility {
  id        String  @id @default(cuid())
  collegeId String
  name      String
  college   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  passwordHash    String
  role            Role             @default(STUDENT)
  createdAt       DateTime         @default(now())
  counselorThread CounselorThread?
  tokens          RefreshToken[]
  reviews         Review[]
  savedItems      SavedItem[]
}

model CounselorThread {
  id        String             @id @default(cuid())
  userId    String             @unique
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  messages  CounselorMessage[]
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model CounselorMessage {
  id        String          @id @default(cuid())
  threadId  String
  role      String
  content   String
  createdAt DateTime        @default(now())
  thread    CounselorThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  savedAt   DateTime @default(now())
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
}

model Review {
  id         String   @id @default(cuid())
  collegeId  String
  userId     String
  rating     Int
  title      String
  body       String
  pros       String?
  cons       String?
  batch      Int?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  college    College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CollegeType {
  GOVERNMENT
  PRIVATE
  DEEMED
}

enum Role {
  STUDENT
}
