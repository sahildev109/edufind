# EduFind .env.example
# Copy this to .env and fill values before running locally.

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# Auth
JWT_SECRET=replace_with_a_long_random_string
REFRESH_TOKEN_SECRET=replace_with_a_different_long_random_string

# Upstash (optional — used for rate-limiting and cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google / Gemini AI credentials
# Either set a single API key or point to a credentials file depending on your SDK setup.
GOOGLE_API_KEY=
# Or (if using service account JSON locally):
GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json

# Optional analytics or deployment flags
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Notes:
# - Do NOT commit real secrets. Keep production credentials in your deployment platform.
# - After updating .env, run `npx prisma generate` and any pending migrations.
